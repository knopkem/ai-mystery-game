# LLM Server configuration
# Copy this file to .env and edit as needed

# --- Inference backend ---
# "mlx"      — Apple Silicon native via mlx-lm (default, recommended for M-series Macs)
# "llamacpp" — Cross-platform GGUF via llama-cpp-python
BACKEND=mlx

# --- MLX backend settings (BACKEND=mlx) ---
# Path to the MLX-format model directory.
#
# Option A — Use your fine-tuned model (after running training/train.py):
#   cp -r training/checkpoints/mlx-model model/mlx-model
#
# Option B — Use the base model directly without fine-tuning:
#   pip install mlx-lm huggingface_hub
#   python -c "from huggingface_hub import snapshot_download; snapshot_download('mlx-community/Meta-Llama-3.1-8B-Instruct-4bit', local_dir='model/mlx-model')"
#
# Other good base models (all fit in 16 GB at 4-bit):
#   mlx-community/Mistral-7B-Instruct-v0.3-4bit
#   mlx-community/Phi-3.5-mini-instruct-4bit
#   mlx-community/Qwen2.5-3B-Instruct-4bit   (faster, lower quality)
MLX_MODEL_PATH=model/mlx-model

# --- llama-cpp backend settings (BACKEND=llamacpp) ---
# Path to GGUF model file produced by training/export_gguf.py
MODEL_PATH=model/murder-mystery.gguf
N_CTX=4096
N_GPU_LAYERS=-1   # -1 = all layers on GPU (Metal on Apple, CUDA on NVIDIA)

# --- Generation settings ---
MAX_TOKENS=512
